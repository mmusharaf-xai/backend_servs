# Server
PORT=8080
ENV=development

# Set to "LOCAL" to use embedded in-memory databases (no Docker needed).
# Leave empty or remove for normal Docker-based Postgres + Redis.
DATABASES_MEMORY=

# Docker Compose (postgres service)
POSTGRES_PASSWORD=eoldev

# PostgreSQL (ignored when DATABASES_MEMORY=LOCAL)
DATABASE_URL=postgres://eol:eoldev@localhost:5432/eol?sslmode=disable

# Redis (ignored when DATABASES_MEMORY=LOCAL)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_ACCESS_TTL=24h

# Refresh token
REFRESH_TOKEN_TTL=168h

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
